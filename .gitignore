# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# IDE
.vscode/
.idea/

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
infrastructure/.terraform/
__pycache__/

# E2E test artifacts (failure screenshots)
scripts/qa/e2e/artifacts/

